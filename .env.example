# Supabase → Project Settings → Data API / API
# Project URL looks like: https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (sb_publishable_...) or legacy anon JWT — never use the secret key here
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Optional: after each submission, POST JSON to this URL (Zapier / Make / Discord webhook, etc.)
# VITE_REVIEW_NOTIFY_WEBHOOK=https://
